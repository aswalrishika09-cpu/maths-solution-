#include <string.h>

int value(char c) {
    switch (c) {
        case 'I': return 1;
        case 'V': return 5;
        case 'X': return 10;
        case 'L': return 50;
        case 'C': return 100;
        case 'D': return 500;
        case 'M': return 1000;
        default: return 0;
    }
}

int romanToInt(char * s) {
    int n = strlen(s);
    int result = 0;
    
    for (int i = 0; i < n; i++) {
        int current_val = value(s[i]);
        
        if (i + 1 < n) {
            int next_val = value(s[i+1]);
            
            if (current_val < next_val) {
                result += next_val - current_val;
                i++;
            } else {
                result += current_val;
            }
        } else {
            result += current_val;
        }
    }
    
    return result;
}
